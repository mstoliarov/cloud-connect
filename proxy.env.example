# API keys for cloud-connect proxy providers
# Copy this file to ~/.claude-provider-proxy/proxy.env and fill in your keys.
# Lines starting with # are ignored. Format: KEY=VALUE (no quotes needed).

# HuggingFace Inference API — https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxx

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-xxx

# Groq — https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxx
